---
import Base from "../../layouts/Base.astro";
import ThemeToggle from "../../components/ThemeToggle.astro";
import LangToggle from "../../components/LangToggle.astro";
import BottomNav from "../../components/BottomNav.astro";
import { useTranslations, localizePath } from "../../i18n/utils";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  // i18n: zh 文章动态路由 —— 只取缺省/zh 文章（en 文章走 en/blog/[...slug].astro）。
  const posts = (await getCollection("blog")).filter(
    (post) => (post.data.lang ?? "zh") === "zh"
  );
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const lang = "zh";
const t = useTranslations(lang);

const { post } = Astro.props;
const { Content } = await render(post);

// i18n: 双语互链 —— 用 translationKey 查 en 版本，存在则 page-top 渲染互链。
let translationHref: string | null = null;
if (post.data.translationKey) {
  const other = (await getCollection("blog")).find(
    (p) =>
      p.data.translationKey === post.data.translationKey &&
      (p.data.lang ?? "zh") === "en"
  );
  if (other) translationHref = localizePath(`/blog/${other.id}`, "en");
}

// i18n: 边注式第二语言片段（marginalia），按顺序渲染。
const marginalia = post.data.marginalia ?? [];
---

<Base
  title={post.data.title}
  description={post.data.description}
  ogType="article"
  ogImage={`/og/blog/${post.id}.png`}
  lang={lang}
>
  <article class="content-page">
    <div class="page-top">
      <a href="/blog" class="back-link">{t("back.blog")}</a>
      <div class="page-top-actions">
        {translationHref && (
          <a href={translationHref} class="translation-link">{t("post.translation.en")}</a>
        )}
        <LangToggle />
        <ThemeToggle lang={lang} />
      </div>
    </div>

    <h1>{post.data.title}</h1>
    <p class="subtitle">{post.data.date?.toLocaleDateString("zh-CN")} {post.data.tags?.map((tag: string) => `#${tag}`).join(" ")}</p>

    <div class="prose">
      <Content />
    </div>

    {marginalia.length > 0 && (
      <div class="marginalia-list">
        {marginalia.map((m) => (
          <aside class="marginalia" lang={m.lang === "en" ? "en" : "zh-CN"}>
            {m.text}
          </aside>
        ))}
      </div>
    )}

    <BottomNav lang={lang} />
  </article>
</Base>

<style>
  .page-top-actions {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .translation-link {
    font-family: "Noto Serif SC", serif;
    color: var(--muted);
    font-size: 0.85rem;
    border-bottom: 1px solid transparent;
    transition: color 0.2s ease, border-color 0.2s ease;
  }
  .translation-link:hover {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }
</style>
