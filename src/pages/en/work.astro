---
// i18n: en work 页，复用 zh work.astro 结构，lang='en'；集合数据直接复用，只换外壳语言。
import Base from "../../layouts/Base.astro";
import ThemeToggle from "../../components/ThemeToggle.astro";
import LangToggle from "../../components/LangToggle.astro";
import BottomNav from "../../components/BottomNav.astro";
import { useTranslations } from "../../i18n/utils";
import { getCollection } from "astro:content";

const lang = "en";
const t = useTranslations(lang);

const projects = await getCollection("projects");

// 旗舰 Alpha 案例：getCollection 不排序，必须手动 sort（按 order 升序）。
const alphaCases = (await getCollection("alpha")).sort(
  (x, y) => (x.data.order ?? 99) - (y.data.order ?? 99),
);
---

<Base title={t("nav.work")} description="Freetrip's projects and works" lang={lang}>
  <article class="content-page">
    <div class="page-top">
      <a href="/en" class="back-link">{t("back")}</a>
      <div class="page-top-actions">
        <LangToggle />
        <ThemeToggle lang={lang} />
      </div>
    </div>

    <h1>{t("nav.work")}</h1>
    <p class="subtitle">Selected projects and works</p>

    {alphaCases.length > 0 && (
      <section class="alpha-section">
        <h2 class="section-label">Flagship Alpha Cases</h2>
        <p class="section-note">Real backtest cases</p>
        <div class="work-grid">
          {alphaCases.map((a) => (
            // alpha 详情页只有 zh 版（不在本期 en 范围），直接链到 zh 详情
            <a href={`/work/alpha/${a.id}`} class="work-card alpha-card">
              <span class="alpha-card-kicker">Alpha</span>
              <h3>{a.data.title}</h3>
              <p>{a.data.problem}</p>
              {(a.data.tags || []).length > 0 && (
                <div class="work-tags">
                  {(a.data.tags || []).map((tag: string) => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
              )}
            </a>
          ))}
        </div>
      </section>
    )}

    <h2 class="section-label">Projects</h2>
    <div class="work-grid">
      {projects.map((project) => (
        <a href={project.data.url || "#"} class="work-card">
          <h3>{project.data.title}</h3>
          <p>{project.data.description}</p>
          {(project.data.tags || []).length > 0 && (
            <div class="work-tags">
              {(project.data.tags || []).map((tag: string) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          )}
        </a>
      ))}
    </div>

    <BottomNav lang={lang} />
  </article>
</Base>

<style>
  .page-top-actions {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .alpha-section {
    margin-top: 2rem;
    text-align: left;
  }

  .section-label {
    font-family: "Noto Serif SC", serif;
    font-size: 1.3rem;
    font-weight: 700;
    text-align: left;
    margin: 2.5rem 0 0.3rem;
  }
  .alpha-section .section-label {
    margin-top: 0;
  }

  .section-note {
    font-size: 0.85rem;
    color: var(--muted);
    margin: 0 0 0.5rem;
    font-style: italic;
    text-align: left;
  }

  .work-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.2rem;
    margin-top: 2rem;
    text-align: left;
  }

  .alpha-card {
    border-left: 3px solid var(--accent);
  }
  .alpha-card-kicker {
    display: inline-block;
    font-family: "Noto Serif SC", serif;
    font-size: 0.72rem;
    letter-spacing: 0.15em;
    color: var(--accent);
    margin-bottom: 0.4rem;
  }
  .alpha-card-stat {
    margin-top: 0.9rem;
    padding-top: 0.7rem;
    border-top: 1px solid var(--border);
    font-size: 0.8rem;
    color: var(--muted);
    font-variant-numeric: tabular-nums;
  }

  .work-card {
    display: flex;
    flex-direction: column;
    padding: 1.4rem;
    border: 1px solid var(--border);
    border-radius: 4px;
    background: var(--card-bg);
    transition: border-color 0.2s ease, transform 0.25s ease;
    text-decoration: none;
    color: inherit;
  }

  .work-card:hover {
    border-color: var(--dots);
    transform: translateY(-2px);
  }

  .work-card h3 {
    margin-bottom: 0.4em;
  }

  .work-card p {
    font-size: 0.95rem;
    color: var(--muted);
    margin-bottom: 0.8em;
  }

  .work-tags {
    display: flex;
    gap: 0.5em;
    margin-top: auto;
  }

  .work-tags .tag {
    font-size: 0.75rem;
    color: var(--accent);
    border: 1px solid var(--border);
    padding: 0.1em 0.5em;
    border-radius: 3px;
  }
</style>
