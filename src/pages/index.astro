---
import Base from "../layouts/Base.astro";
import TableOfContents from "../components/TableOfContents.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
---

<Base title="Freetrip">
  <main class="home">
    <header class="home-header page-enter">
      <h1 class="name">Freetrip</h1>
      <p class="identity">开发者 / 创作者</p>
    </header>

    <section class="home-nav">
      <TableOfContents />
    </section>

    <footer class="home-footer page-enter">
      <span class="volume-wrap">
        <span class="volume-label">第一卷</span>
        <ThemeToggle />
      </span>
    </footer>
  </main>
</Base>

<style>
  .home {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 3rem 2rem;
    max-width: 680px;
    margin: 0 auto;
  }

  .home-header {
    margin-bottom: 3rem;
    text-align: center;
  }

  .name {
    font-family: "Noto Serif SC", serif;
    margin-bottom: 0.1em;
  }

  .identity {
    font-size: 1.1rem;
    color: var(--muted);
    font-weight: 300;
  }

  .home-nav {
    flex: 0;
  }

  .home-footer {
    margin-top: 4rem;
    display: flex;
    justify-content: center;
    font-size: 18px;
    color: var(--muted);
  }

  .volume-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6em;
  }

  .volume-label {
    font-family: "Noto Serif SC", serif;
    letter-spacing: 0.15em;
    color: #2c2c2c;
    font-weight: 600;
  }

  :global([data-theme="dark"]) .volume-label {
    color: #ffffff;
  }

  .home-header.page-enter {
    animation: fadeUp 0.6s ease both;
    animation-delay: 0.05s;
  }

  :global(.toc-list li.page-enter:nth-child(1)) { animation: fadeUp 0.5s ease both; animation-delay: 0.22s; }
  :global(.toc-list li.page-enter:nth-child(2)) { animation: fadeUp 0.5s ease both; animation-delay: 0.30s; }
  :global(.toc-list li.page-enter:nth-child(3)) { animation: fadeUp 0.5s ease both; animation-delay: 0.38s; }
  :global(.toc-list li.page-enter:nth-child(4)) { animation: fadeUp 0.5s ease both; animation-delay: 0.46s; }
  :global(.toc-list li.page-enter:nth-child(5)) { animation: fadeUp 0.5s ease both; animation-delay: 0.54s; }
  :global(.toc-list li.page-enter:nth-child(6)) { animation: fadeUp 0.5s ease both; animation-delay: 0.62s; }

  .home-footer.page-enter {
    animation: fadeUp 0.5s ease both;
    animation-delay: 0.75s;
  }
</style>
