---
import VinylPlayer from "../components/VinylPlayer.astro";
import InkCanvas from "../components/InkCanvas.astro";
import { ClientRouter } from "astro:transitions";
import { siteMeta, buildPersonJsonLd } from "../data/siteMeta";

interface Props {
  title: string;
  description?: string;
  ogType?: "website" | "article";
}

const {
  title,
  description = siteMeta.description,
  ogType = "website",
} = Astro.props;

// 首页标题为站名本身，其余为「页名 · 站名」
const pageTitle =
  title === siteMeta.siteName ? siteMeta.siteName : `${title} · ${siteMeta.siteName}`;

// canonical / OG 绝对 URL —— 必须用 Astro.site 守卫，未配 site 时回退相对路径
const canonical = Astro.site
  ? new URL(Astro.url.pathname, Astro.site).href
  : Astro.url.pathname;
const ogImageUrl =
  Astro.site && siteMeta.ogImage
    ? new URL(siteMeta.ogImage, Astro.site).href
    : (siteMeta.ogImage ?? "");

// Person JSON-LD —— 用绝对站点 URL；放静态 head，不进 is:inline、不参与 View Transitions
const jsonLd = buildPersonJsonLd(Astro.site ? Astro.site.href : siteMeta.url);
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    {/* Open Graph */}
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={siteMeta.siteName} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={siteMeta.locale} />
    {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}

    {/* Twitter Card */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    {ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@300;400;500;600;700&family=Noto+Serif+SC:wght@400;600;700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/aplayer@1.10.1/dist/APlayer.min.css" />
    <title>{pageTitle}</title>
    <ClientRouter />
    <script is:inline>
      (function () {
        function getDesiredTheme() {
          var t = localStorage.getItem("theme");
          if (t === "dark" || t === "light") return t;
          var h = new Date().getHours();
          return (h < 6 || h >= 18) ? "dark" : "light";
        }
        // 首次加载：立刻打上属性，避免 FOUC
        if (getDesiredTheme() === "dark") {
          document.documentElement.setAttribute("data-theme", "dark");
        }
        // ClientRouter 切页前：把主题预先写到新文档的 html 上，避免白闪
        document.addEventListener("astro:before-swap", function (e) {
          if (getDesiredTheme() === "dark") {
            e.newDocument.documentElement.setAttribute("data-theme", "dark");
          } else {
            e.newDocument.documentElement.removeAttribute("data-theme");
          }
        });
      })();
    </script>
    <script is:inline src="https://cdn.jsdelivr.net/npm/aplayer@1.10.1/dist/APlayer.min.js"></script>
    <script is:inline>
    (function () {
      if (!window._animInit) {
        window._animInit = true;
        document.addEventListener('astro:after-swap', function () {
          var els = document.querySelectorAll('.page-enter');
          els.forEach(function (el) { el.classList.remove('page-enter'); });
          void document.body.offsetWidth;
          els.forEach(function (el) { el.classList.add('page-enter'); });
        });
      }
    })();
    </script>
    <script is:inline>
    (function () {
      if (window._vinylInit) return;
      window._vinylInit = true;
      window._vinylState = { isPlaying: false, ap: null, volume: 70 };

      // Create APlayer container on <html> so it survives page swaps
      var apDiv = document.createElement("div");
      apDiv.id = "vinyl-aplayer";
      apDiv.style.cssText = "position:fixed!important;bottom:-9999px!important;left:-9999px!important;width:0!important;height:0!important;overflow:hidden!important;opacity:0!important;pointer-events:none!important;z-index:-999!important;";
      document.documentElement.appendChild(apDiv);

      var songIds = [2151956989, 1831469100, 31649312, 2692441576, 1903408778, 1383927071, 26441613, 403180, 22687828, 1803545365, 529668945, 1880714348];
      var endpoints = [
        "https://api.injahow.cn/meting/",
        "https://meting.qjqq.cn/",
        "https://api.i-meto.com/meting/"
      ];

      function fetchSong(id) {
        var i = 0;
        function tryNext() {
          if (i >= endpoints.length) return Promise.resolve(null);
          var url = endpoints[i] + "?type=song&id=" + id + "&server=netease";
          i++;
          return fetch(url).then(function (r) { return r.json(); }).then(function (data) {
            if (!data || data.length === 0 || !data[0].url) return tryNext();
            return data[0];
          }).catch(function () { return tryNext(); });
        }
        return tryNext();
      }

      function fetchAllSongs() {
        Promise.all(songIds.map(fetchSong))
          .then(function (songs) {
            var valid = songs.filter(Boolean);
            if (valid.length === 0) {
              console.error("VinylPlayer: No songs could be loaded");
              return;
            }
            initPlayer(valid);
          });
      }

      function initPlayer(audioData) {
        var ap = new APlayer({
          container: apDiv,
          audio: audioData,
          autoplay: false,
          theme: "#8b7355",
          loop: "all",
          volume: 0.7
        });

        window._vinylState.ap = ap;

        // Force sync volume on first play
        ap.on("canplay", function () {
          ap.volume(window._vinylState.volume / 100);
        }, { once: true });

        ap.on("play", function () {
          window._vinylState.isPlaying = true;
          syncPlayBtn();
        });

        ap.on("pause", function () {
          window._vinylState.isPlaying = false;
          syncPlayBtn();
        });

        ap.on("listswitch", function () {
          swapRecord();
        });
      }

      function swapRecord() {
        var wrap = document.getElementById("vinyl-wrap");
        if (!wrap) return;
        var oldRecord = wrap.querySelector(".vinyl-record");
        if (!oldRecord) return;

        var newRecord = document.createElement("div");
        newRecord.className = "vinyl-record";
        newRecord.innerHTML =
          '<div class="vinyl-grooves"></div>' +
          '<div class="vinyl-label"><span class="vinyl-label-text" style="font-size:4.5rem;">♪</span></div>' +
          '<div class="vinyl-highlight"></div>';
        newRecord.style.top = "-400px";
        newRecord.style.zIndex = "2";
        newRecord.style.transition = "top 0.8s cubic-bezier(0.22,1,0.36,1), opacity 2s ease";

        // Old record fades out in sync
        oldRecord.style.transition = "opacity 0.8s cubic-bezier(0.22,1,0.36,1)";
        oldRecord.style.opacity = "0";

        var next = oldRecord.nextSibling;
        if (next) { wrap.insertBefore(newRecord, next); }
        else { wrap.appendChild(newRecord); }

        requestAnimationFrame(function () {
          requestAnimationFrame(function () {
            newRecord.style.top = "0";
          });
        });

        newRecord.addEventListener("transitionend", function handler(e) {
          if (e.propertyName !== "top") return;
          newRecord.removeEventListener("transitionend", handler);
          oldRecord.remove();
          newRecord.style.top = "";
          newRecord.style.zIndex = "";
          newRecord.style.transition = "";
        });
      }

      function syncPlayBtn() {
        var btn = document.getElementById("vc-play");
        if (!btn) return;
        if (window._vinylState.isPlaying) {
          btn.classList.add("is-playing");
        } else {
          btn.classList.remove("is-playing");
        }
      }

      function waitForAPlayer() {
        if (typeof APlayer !== "undefined") {
          fetchAllSongs();
        } else {
          setTimeout(waitForAPlayer, 200);
        }
      }
      waitForAPlayer();

      // Delegated click — survives page swaps
      document.addEventListener("click", function (e) {
        var ap = window._vinylState.ap;
        if (!ap) return;

        // Control bar buttons
        var prevBtn = document.getElementById("vc-prev");
        var playBtn = document.getElementById("vc-play");
        var nextBtn = document.getElementById("vc-next");
        var volBtn = document.getElementById("vc-vol-icon");

        if (prevBtn && prevBtn.contains(e.target)) { ap.skipBack(); return; }
        if (nextBtn && nextBtn.contains(e.target)) { ap.skipForward(); return; }
        if (playBtn && playBtn.contains(e.target)) {
          if (window._vinylState.isPlaying) { ap.pause(); } else { ap.play(); }
          return;
        }
        if (volBtn && volBtn.contains(e.target)) {
          var slider = document.getElementById("vc-vol-slider");
          if (slider) {
            var cur = parseFloat(slider.value);
            slider.value = cur > 0 ? 0 : 70;
            ap.volume(cur > 0 ? 0 : 0.7);
          }
          return;
        }

        // Click inside controls — don't fall through to vinyl-wrap toggle
        var controls = document.getElementById("vinyl-controls");
        if (controls && controls.contains(e.target)) return;

        // Click on vinyl-wrap (not on control buttons) to toggle play
        var wrap = document.getElementById("vinyl-wrap");
        if (wrap && wrap.contains(e.target)) {
          if (window._vinylState.isPlaying) { ap.pause(); } else { ap.play(); }
        }
      });

      // Volume slider
      document.addEventListener("input", function (e) {
        if (e.target.id === "vc-vol-slider") {
          var ap = window._vinylState.ap;
          var vol = parseInt(e.target.value);
          window._vinylState.volume = vol;
          if (ap) ap.volume(vol / 100);
        }
      });

      // After page swap, sync theme instantly, then sync player controls
      document.addEventListener("astro:after-swap", function () {
        var t = localStorage.getItem("theme");
        if (t === "dark" || t === "light") {
          if (t === "dark") document.documentElement.setAttribute("data-theme", "dark");
          else document.documentElement.removeAttribute("data-theme");
        } else {
          var h = new Date().getHours();
          if (h < 6 || h >= 18) document.documentElement.setAttribute("data-theme", "dark");
          else document.documentElement.removeAttribute("data-theme");
        }
        setTimeout(function () {
          syncPlayBtn();
          var ap = window._vinylState.ap;
          var vol = window._vinylState.volume;
          if (ap) ap.volume(vol / 100);
          var slider = document.getElementById("vc-vol-slider");
          if (slider) slider.value = vol;
        }, 50);
      });
    })();
    </script>
    {/* 结构化数据：Person JSON-LD。必须用 set:html 避免 HTML 转义；静态 head，不进 is:inline */}
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <InkCanvas transition:persist="ink" />
    <VinylPlayer />
    <slot />
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>
