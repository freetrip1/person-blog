---
// 「问问关于我」v2：流式 + 钢笔逐笔书写 + 写完后自动淡去。
// 本组件只负责结构 + 样式；交互脚本统一放在 Base.astro 的 head（全局 document 委托），
// 因为组件 body 内的 inline 脚本在 ClientRouter 切页时不会重跑——放 Base 才能跨页持久。
// 桌面宽屏(≥1180px)写在左侧页边空白，窄屏降级到输入框下方。
---

<section class="askme">
  <p class="askme-hint">想了解我？在这里问一句，回答会一笔一画写给你看。</p>
  <form class="askme-form" id="askme-form">
    <input
      class="askme-input"
      id="askme-input"
      type="text"
      maxlength="500"
      placeholder="比如：他做过什么 AI 的工作？"
      autocomplete="off"
      aria-label="问问关于我的事"
    />
    <button class="askme-btn" type="submit">问</button>
  </form>
</section>

<aside class="askme-ink" id="askme-ink" hidden aria-live="polite">
  <div class="askme-ink-paper">
    <span class="askme-ink-text" id="askme-ink-text"></span><img
      class="askme-nib"
      id="askme-nib"
      src="/cursor-feather-light.svg"
      alt=""
      aria-hidden="true"
      hidden
    />
  </div>
</aside>

<style>
  .askme {
    margin: 2.5rem 0 1rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }
  .askme-hint {
    font-size: 0.85rem;
    color: var(--muted);
    font-style: italic;
    margin: 0 0 0.8rem;
  }
  .askme-form {
    display: flex;
    gap: 0.5rem;
  }
  .askme-input {
    flex: 1;
    min-width: 0;
    padding: 0.6rem 0.8rem;
    border: 1px solid var(--border);
    border-radius: 4px;
    background: var(--card-bg);
    color: var(--fg);
    font-family: inherit;
    font-size: 0.95rem;
  }
  .askme-input:focus {
    outline: none;
    border-color: var(--accent);
  }
  .askme-btn {
    padding: 0.6rem 1.2rem;
    border: 1px solid var(--accent);
    border-radius: 4px;
    background: var(--accent);
    color: var(--bg);
    font-family: "Noto Serif SC", serif;
    cursor: pointer;
    white-space: nowrap;
  }
  .askme-btn:disabled {
    opacity: 0.5;
    cursor: default;
  }

  /* 书写区：默认在流内（窄屏）；写完淡出由 .is-fading 触发 */
  .askme-ink {
    margin-top: 1.2rem;
    transition: opacity 1.1s ease;
  }
  .askme-ink.is-fading {
    opacity: 0;
  }
  .askme-ink-paper {
    padding: 1rem 1.2rem;
    border-left: 3px solid var(--accent);
    background: var(--card-bg);
    border-radius: 4px;
  }
  .askme-ink-text {
    font-family: "Noto Serif SC", serif;
    font-size: 1rem;
    line-height: 2;
    color: var(--fg);
    white-space: pre-wrap;
    word-break: break-word;
  }
  /* 每个字「落墨」：淡入 + 由晕开到清晰 */
  .ink-char {
    display: inline;
    animation: inkIn 0.3s ease both;
  }
  @keyframes inkIn {
    from {
      opacity: 0;
      filter: blur(1.5px);
    }
    to {
      opacity: 1;
      filter: none;
    }
  }
  /* 羽毛笔尖：跟在已写文字末尾，书写时轻微起伏 */
  .askme-nib {
    width: 22px;
    height: 22px;
    vertical-align: -0.45em;
    margin-left: 1px;
    animation: nibBob 0.6s ease-in-out infinite;
    pointer-events: none;
  }
  @keyframes nibBob {
    0%,
    100% {
      transform: translateY(0) rotate(0deg);
    }
    50% {
      transform: translateY(-2px) rotate(-3deg);
    }
  }
  .askme-error {
    color: var(--accent);
    font-style: italic;
  }

  /* 桌面宽屏：钉在左侧页边空白，像写在书的页边 */
  @media (min-width: 1180px) {
    .askme-ink {
      position: fixed;
      top: 16vh;
      left: 2.2rem;
      width: 250px;
      max-height: 68vh;
      overflow-y: auto;
      margin-top: 0;
      z-index: 50;
    }
    .askme-ink-paper {
      background: transparent;
      border-left: 2px solid var(--dots);
      box-shadow: none;
    }
    .askme-ink-text {
      font-size: 0.95rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .ink-char {
      animation: none;
    }
    .askme-nib {
      animation: none;
    }
  }
</style>
