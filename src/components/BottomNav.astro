---
interface NavItem {
  label: string;
  href: string;
  page: string;
}

const items: NavItem[] = [
  { label: "关于", href: "/about", page: "i" },
  { label: "作品集", href: "/work", page: "ii" },
  { label: "想法", href: "/blog", page: "iii" },
  { label: "漫游", href: "/wander", page: "iv" },
  { label: "档案", href: "/archive", page: "v" },
  { label: "友链", href: "/friends", page: "vi" },
];

import { siteMeta } from "../data/siteMeta";

// SVG 图标不入数据文件；按 label 取 icon。无对应图标的项（邮箱）走 email-btn 分支。
const iconMap: Record<string, string> = {
  GitHub:
    '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>',
  Twitter:
    '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>',
  Instagram:
    '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/></svg>',
};

// 仅渲染有图标的社交项 + 邮箱。WorldQuant BRAIN 等仅出现在 JSON-LD sameAs（无 icon、非邮箱），暂不展示。
const socials = siteMeta.social
  .filter((s) => s.label === "电子邮件" || iconMap[s.label])
  .map((s) => ({ label: s.label, href: s.href, icon: iconMap[s.label] }));
---

<nav class="bottom-nav">
  <div class="social-links">
    {socials.map((s) => (
      s.icon ? (
        <a href={s.href} target="_blank" rel="noopener" class="social-link" aria-label={s.label}>
          <span class="social-icon" set:html={s.icon} />
        </a>
      ) : (
        <button class="social-link email-btn" aria-label={s.label}>
          <span class="social-label">{s.label}</span>
          <span class="email-popup">{s.href.replace("mailto:", "")}</span>
        </button>
      )
    ))}
  </div>

  <ul class="toc-list">
    {items.map((item) => (
      <li>
        <a href={item.href} class="toc-item">
          <span class="toc-label">{item.label}</span>
          <span class="toc-dots" />
          <span class="toc-page">{item.page}</span>
        </a>
      </li>
    ))}
  </ul>

  <div class="volume-wrap">
    <span class="volume-label">第一卷</span>
  </div>
</nav>

<style>
  .bottom-nav {
    margin-top: 3rem;
    padding-top: 0.8rem;
    border-top: 2px solid var(--dots);
    text-align: left;
  }

  .social-links {
    display: flex;
    gap: 1.2em;
    margin-bottom: 0.8rem;
    padding-bottom: 0.8rem;
    border-bottom: 2px solid var(--dots);
    flex-wrap: wrap;
  }

  .social-links .social-link:first-child {
    margin-right: auto;
  }

  .social-link {
    display: flex;
    align-items: center;
    gap: 0.4em;
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--muted);
    transition: color 0.2s ease;
    text-decoration: none;
  }

  .social-link:hover {
    color: var(--accent);
    cursor: pointer;
  }

  .email-btn {
    position: relative;
    border: none;
    background: none;
    font-family: inherit;
    padding: 0;
  }

  .email-popup {
    position: absolute;
    bottom: calc(100% + 8px);
    left: 0;
    background: var(--fg);
    color: var(--bg);
    font-size: 0.8rem;
    font-weight: 500;
    padding: 0.4em 0.8em;
    border-radius: 4px;
    white-space: nowrap;
    opacity: 0;
    transform: translateY(4px);
    pointer-events: none;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .email-popup::after {
    content: "";
    position: absolute;
    top: 100%;
    left: 1em;
    border: 5px solid transparent;
    border-top-color: var(--fg);
  }

  .email-btn:hover .email-popup {
    opacity: 1;
    transform: translateY(0);
  }

  .social-icon {
    width: 1.5em;
    height: 1.5em;
    display: flex;
    align-items: center;
  }

  .social-icon :global(svg) {
    width: 1.5em;
    height: 1.5em;
  }

  .volume-wrap {
    margin-top: 1.5rem;
    text-align: center;
    font-size: 18px;
  }

  .volume-label {
    font-family: "Noto Serif SC", serif;
    letter-spacing: 0.15em;
    color: #2c2c2c;
    font-weight: 600;
  }

  :global([data-theme="dark"]) .volume-label {
    color: #ffffff;
  }
</style>
