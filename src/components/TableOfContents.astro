---
// i18n: label 走字典(t)，href 经 localizePath；罗马数字 i–viii 与语言无关，保持不变。
// 注意：此 items 数组与 BottomNav.astro 重复，改一处必须同步改另一处。
import { useTranslations, localizePath } from "../i18n/utils";

interface Props {
  lang?: "zh" | "en";
}
const { lang = "zh" } = Astro.props;
const t = useTranslations(lang);

interface NavItem {
  key: Parameters<typeof t>[0];
  href: string;
  page: string;
}

const items: NavItem[] = [
  { key: "nav.about", href: "/about", page: "i" },
  { key: "nav.work", href: "/work", page: "ii" },
  { key: "nav.blog", href: "/blog", page: "iii" },
  { key: "nav.wander", href: "/wander", page: "iv" },
  { key: "nav.archive", href: "/archive", page: "v" },
  { key: "nav.friends", href: "/friends", page: "vi" },
  { key: "nav.now", href: "/now", page: "vii" },
];
---

<nav class="toc">
  <ul class="toc-list">
    {items.map((item) => (
      <li class="page-enter">
        <a href={localizePath(item.href, lang)} class="toc-item">
          <span class="toc-label">{t(item.key)}</span>
          <span class="toc-dots" />
          <span class="toc-page">{item.page}</span>
        </a>
      </li>
    ))}
  </ul>
</nav>
