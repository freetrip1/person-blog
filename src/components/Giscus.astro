---
interface Props {
  repo?: string;
  repoId?: string;
  category?: string;
  categoryId?: string;
  mapping?: string;
  strict?: string;
  reactionsEnabled?: string;
  emitMetadata?: string;
  inputPosition?: string;
  lang?: string;
}

const {
  repo = "freetrip1/person-blog",
  repoId = "R_kgDOSPaaAA",
  category = "Mutual Links",
  categoryId = "DIC_kwDOSPaaAM4C79gT",
  mapping = "pathname",
  strict = "0",
  reactionsEnabled = "1",
  emitMetadata = "0",
  inputPosition = "top",
  lang = "zh-CN",
} = Astro.props;
---

<div class="giscus-wrapper">
  <div class="giscus"></div>
</div>

<script is:inline>
  function loadGiscus() {
    var container = document.querySelector(".giscus");
    if (!container || container.querySelector("iframe")) return;
    container.innerHTML = "";

    var isDark = document.documentElement.getAttribute("data-theme") === "dark";
    var script = document.createElement("script");
    script.src = "https://giscus.app/client.js";
    script.setAttribute("data-repo", "freetrip1/person-blog");
    script.setAttribute("data-repo-id", "R_kgDOSPaaAA");
    script.setAttribute("data-category", "Mutual Links");
    script.setAttribute("data-category-id", "DIC_kwDOSPaaAM4C79gT");
    script.setAttribute("data-mapping", "pathname");
    script.setAttribute("data-strict", "0");
    script.setAttribute("data-reactions-enabled", "1");
    script.setAttribute("data-emit-metadata", "0");
    script.setAttribute("data-input-position", "top");
    script.setAttribute("data-theme", isDark ? "dark" : "light");
    script.setAttribute("data-lang", "zh-CN");
    script.setAttribute("crossorigin", "anonymous");
    script.async = true;
    container.appendChild(script);
  }

  function updateGiscusTheme() {
    var isDark = document.documentElement.getAttribute("data-theme") === "dark";
    var theme = isDark ? "dark" : "light";
    var iframe = document.querySelector("iframe.giscus-frame");
    if (iframe) {
      iframe.contentWindow.postMessage(
        { giscus: { setConfig: { theme: theme } } },
        "https://giscus.app"
      );
    }
  }

  // 初始加载
  loadGiscus();

  // 监听 data-theme 变化
  new MutationObserver(updateGiscusTheme).observe(document.documentElement, {
    attributes: true,
    attributeFilter: ["data-theme"],
  });

  // Astro 页面切换后重新加载
  document.addEventListener("astro:after-swap", loadGiscus);
</script>

<style>
  .giscus-wrapper {
    margin-top: 2rem;
  }
</style>
