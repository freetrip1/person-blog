---
interface Props {
  repo?: string;
  repoId?: string;
  category?: string;
  categoryId?: string;
  mapping?: string;
  strict?: string;
  reactionsEnabled?: string;
  emitMetadata?: string;
  inputPosition?: string;
  lang?: string;
}

const {
  repo = "freetrip1/person-blog",
  repoId = "R_kgDOSPaaAA",
  category = "Mutual Links",
  categoryId = "DIC_kwDOSPaaAM4C79gT",
  mapping = "pathname",
  strict = "0",
  reactionsEnabled = "1",
  emitMetadata = "0",
  inputPosition = "top",
  lang = "zh-CN",
} = Astro.props;
---

<div class="giscus-wrapper">
  <div class="giscus"></div>
</div>

<script is:inline>
  function giscusThemeUrl() {
    var isDark = document.documentElement.getAttribute("data-theme") === "dark";
    // dev (HTTP) 下 giscus.app (HTTPS) iframe 无法加载 HTTP 资源，回退到内置主题
    if (window.location.protocol !== "https:") {
      return isDark ? "dark" : "light";
    }
    var file = isDark ? "/giscus-dark.css" : "/giscus-light.css";
    return window.location.origin + file;
  }

  function prefetchAlternateTheme() {
    if (window.location.protocol !== "https:") return;
    var isDark = document.documentElement.getAttribute("data-theme") === "dark";
    var alternate = isDark ? "light" : "dark";
    var origin = window.location.origin;
    var url = origin + "/giscus-" + alternate + ".css";
    if (document.querySelector('link[rel="prefetch"][href="' + url + '"]')) return;
    var link = document.createElement("link");
    link.rel = "prefetch";
    link.as = "style";
    link.href = url;
    document.head.appendChild(link);
  }

  function loadGiscus() {
    var container = document.querySelector(".giscus");
    if (!container || container.querySelector("iframe")) return;
    container.innerHTML = "";

    prefetchAlternateTheme();

    var script = document.createElement("script");
    script.src = "https://giscus.app/client.js";
    script.setAttribute("data-repo", "freetrip1/person-blog");
    script.setAttribute("data-repo-id", "R_kgDOSPaaAA");
    script.setAttribute("data-category", "Mutual Links");
    script.setAttribute("data-category-id", "DIC_kwDOSPaaAM4C79gT");
    script.setAttribute("data-mapping", "pathname");
    script.setAttribute("data-strict", "0");
    script.setAttribute("data-reactions-enabled", "1");
    script.setAttribute("data-emit-metadata", "0");
    script.setAttribute("data-input-position", "top");
    script.setAttribute("data-theme", giscusThemeUrl());
    script.setAttribute("data-lang", "zh-CN");
    script.setAttribute("crossorigin", "anonymous");
    script.async = true;
    container.appendChild(script);
  }

  function updateGiscusTheme() {
    var iframe = document.querySelector("iframe.giscus-frame");
    if (!iframe) return;
    // 切换前瞬间隐藏 iframe，让用户看到的是页面背景色（已经是新主题色）
    iframe.style.transition = "none";
    iframe.style.opacity = "0";
    iframe.contentWindow.postMessage(
      { giscus: { setConfig: { theme: giscusThemeUrl() } } },
      "https://giscus.app"
    );
    // iframe 在背后完成主题切换后，淡入显示
    setTimeout(function () {
      iframe.style.transition = "opacity 0.25s ease";
      iframe.style.opacity = "1";
    }, 380);
  }

  // 初始加载
  loadGiscus();

  // 监听 data-theme 变化
  new MutationObserver(updateGiscusTheme).observe(document.documentElement, {
    attributes: true,
    attributeFilter: ["data-theme"],
  });

  // Astro 页面切换后重新加载
  document.addEventListener("astro:after-swap", loadGiscus);
</script>

<style>
  .giscus-wrapper {
    margin-top: 2rem;
  }
</style>
